<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BenchmarkTools.Core.ViewModels;assembly=BenchmarkTools.Core"
             xmlns:models="clr-namespace:BenchmarkTools.Core.Models;assembly=BenchmarkTools.Core"
             x:DataType="vm:SettingsViewModel"
             x:Class="BenchmarkTools.Views.SettingsPage"
             Title="{Binding Title}">
    <VerticalStackLayout Padding="20" Spacing="16">
        <Label Text="Settings" Style="{StaticResource Headline}" />
        <Label Text="Theme" />
        <Picker AutomationId="SettingsThemePicker"
                ItemsSource="{Binding AvailableThemes}"
                SelectedItem="{Binding SelectedTheme}" />
        <Button AutomationId="SettingsApplyThemeButton"
                Text="Apply Theme"
                Command="{Binding ApplyThemeCommand}" />
    </VerticalStackLayout>
</ContentPage>

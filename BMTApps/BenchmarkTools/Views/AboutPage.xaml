<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BenchmarkTools.Core.ViewModels;assembly=BenchmarkTools.Core"
             x:DataType="vm:AboutViewModel"
             x:Class="BenchmarkTools.Views.AboutPage"
             Title="{Binding Title}">
    <VerticalStackLayout Padding="20" Spacing="16">
        <Label Text="About" Style="{StaticResource Headline}" />
        <Label AutomationId="AboutAppNameLabel"
               Text="{Binding AppName, StringFormat='App: {0}'}" />
        <Label AutomationId="AboutVersionLabel"
               Text="{Binding AppVersion, StringFormat='Version: {0}'}" />
        <Label AutomationId="AboutDescriptionLabel"
               Text="{Binding Description}" />
    </VerticalStackLayout>
</ContentPage>
